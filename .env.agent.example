# ─── Database (sama dengan project PRISMA utama) ───────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Anthropic (untuk generate report via Claude) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Fonnte (sama seperti WA bot) ──────────────────────────────────────────
FONNTE_TOKEN=your-fonnte-token-here

# ─── Target WA — nomor tujuan, pisah koma jika lebih dari 1 ───────────────
# Format: kode negara + nomor tanpa +
# Contoh: "6281234567890" atau "6281234567890,6289876543210"
REPORT_WA_TARGETS=6281234567890

# ─── Jadwal kirim (UTC, default 23:00 = 06:00 WIB) ───────────────────────
REPORT_SEND_TIME_UTC=23:00

# ─── Testing: set RUN_NOW=true untuk langsung trigger kirim saat startup ──
RUN_NOW=false
